{
  "title": "System Health",
  "uid": "system-health",
  "description": "HTTP rates, DB connection pool, RabbitMQ queue depths, Redis stats",
  "refresh": "15s",
  "schemaVersion": 38,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["devops-copilot", "infrastructure", "health"],
  "panels": [
    {
      "id": 1,
      "title": "DB Active Connections",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "hikaricp_connections_active", "legendFormat": "Active" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0, "max": 20, "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 14 }, { "color": "red", "value": 18 } ] } } }
    },
    {
      "id": 2,
      "title": "DB Pending (waiting for connection)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "hikaricp_connections_pending", "legendFormat": "Pending" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0, "max": 20, "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 } ] } } }
    },
    {
      "id": 3,
      "title": "RabbitMQ Analysis Queue Depth",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rabbitmq_queue_messages{queue=\"incident.analysis.queue\"}", "legendFormat": "Analysis Queue" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0, "max": 50, "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 } ] } } }
    },
    {
      "id": 4,
      "title": "Dead Letter Queue Depth",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rabbitmq_queue_messages{queue=\"incident.dlq\"}", "legendFormat": "DLQ" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0, "max": 20, "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } }
    },
    {
      "id": 5,
      "title": "HTTP Request Rate & Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\"}[1m])", "legendFormat": "req/s total" },
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\",status=~\"5..\"}[1m])", "legendFormat": "5xx req/s" },
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\",status=~\"4..\"}[1m])", "legendFormat": "4xx req/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "title": "API p99 Response Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"spring-boot\"}[5m]))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"spring-boot\"}[5m]))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"spring-boot\"}[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [ { "color": "transparent", "value": null }, { "color": "red", "value": 3 } ] } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "title": "Database Connection Pool Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "hikaricp_connections_active", "legendFormat": "Active" },
        { "datasource": "Prometheus", "expr": "hikaricp_connections_idle", "legendFormat": "Idle" },
        { "datasource": "Prometheus", "expr": "hikaricp_connections_pending", "legendFormat": "Pending" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "title": "RabbitMQ Queue Depths Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rabbitmq_queue_messages{queue=\"incident.analysis.queue\"}", "legendFormat": "Analysis Queue" },
        { "datasource": "Prometheus", "expr": "rabbitmq_queue_messages{queue=\"incident.results.queue\"}", "legendFormat": "Results Queue" },
        { "datasource": "Prometheus", "expr": "rabbitmq_queue_messages{queue=\"incident.dlq\"}", "legendFormat": "DLQ" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "version": 1
}
