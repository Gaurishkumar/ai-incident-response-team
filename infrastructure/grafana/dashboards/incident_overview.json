{
  "title": "Incident Overview",
  "uid": "incident-overview",
  "description": "Total incidents, active counts, severity breakdown, resolution rate",
  "refresh": "30s",
  "schemaVersion": 38,
  "timezone": "browser",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["devops-copilot", "incidents"],
  "panels": [
    {
      "id": 1,
      "title": "Total Incidents Submitted",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "incidents_submitted_total", "legendFormat": "Total" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#F59E0B", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Total Incidents Resolved",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "incidents_resolved_total", "legendFormat": "Resolved" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#00FFA3", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 3,
      "title": "RabbitMQ Publish Failures",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rabbitmq_publish_failures_total", "legendFormat": "Failures" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#FF2040", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Active Analyses (AI Pipeline)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "active_analyses", "legendFormat": "Active" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#22D3EE", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Incidents Submitted Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(incidents_submitted_total[5m]) * 300", "legendFormat": "Submitted / 5m" },
        { "datasource": "Prometheus", "expr": "rate(incidents_resolved_total[5m]) * 300", "legendFormat": "Resolved / 5m" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "title": "Average Analysis Duration",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(analysis_pipeline_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(analysis_pipeline_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(analysis_pipeline_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "title": "Analysis Status Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "increase(analysis_pipeline_duration_seconds_count{analysis_status=\"COMPLETED\"}[1h])", "legendFormat": "COMPLETED" },
        { "datasource": "Prometheus", "expr": "increase(analysis_pipeline_duration_seconds_count{analysis_status=\"PARTIAL\"}[1h])", "legendFormat": "PARTIAL" },
        { "datasource": "Prometheus", "expr": "increase(analysis_pipeline_duration_seconds_count{analysis_status=\"FAILED\"}[1h])", "legendFormat": "FAILED" }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "id": 8,
      "title": "HTTP Request Rate (Backend)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\"}[1m])", "legendFormat": "{{ uri }} {{ status }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "version": 1
}
