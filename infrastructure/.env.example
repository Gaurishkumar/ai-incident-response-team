# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Superuser password (used only to initialize the DB)
POSTGRES_ROOT_PASSWORD=change-me-strong-root-password

# Spring Boot read/write user — must match backend/.env SPRING_DATASOURCE_PASSWORD
APPWRITER_PASSWORD=change-me-writer-password

# FastAPI read-only user — must match ai-service/.env POSTGRES_READ_URL password
APPREADER_PASSWORD=change-me-reader-password

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=devops_rabbit
RABBITMQ_PASSWORD=change-me-rabbitmq-password

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana-password
