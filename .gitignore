ai-service/__pycache__/
ai-service/.venv/
ai-service/venv/
ai-service/.pytest_cache/
ai-service/htmlcov/
ai-service/.coverage
ai-service/dist/
ai-service/*.egg-info/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

