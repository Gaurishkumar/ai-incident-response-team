# ─── Environment / Secrets ───────────────────────────────────────────────────
# NEVER commit real .env files — copy .env.example and fill in values locally
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.local
**/.env.production
**/.env.staging
# Keep the example templates (they contain only placeholder values)
!**/.env.example
!**/.env.local.example

